{
  "name": "@mcptoolshop/repo-knowledge",
  "version": "1.0.1",
  "description": "Repo knowledge system — relational catalog with full-text search, audit evidence, and MCP access",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "rk": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./mcp": {
      "import": "./dist/mcp/server.js",
      "types": "./dist/mcp/server.d.ts"
    }
  },
  "files": [
    "dist",
    "data/control-registry.json",
    "templates",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsup && node scripts/postbuild.js",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "verify": "npm run build && npm run typecheck && npm run lint && npm run test",
    "mcp": "node dist/mcp/server.js",
    "prepublishOnly": "npm run verify"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "commander": "^13.1.0",
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "author": "mcp-tool-shop <64996768+mcp-tool-shop@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcp-tool-shop-org/repo-knowledge.git"
  },
  "homepage": "https://github.com/mcp-tool-shop-org/repo-knowledge#readme",
  "bugs": {
    "url": "https://github.com/mcp-tool-shop-org/repo-knowledge/issues"
  },
  "keywords": [
    "repo-knowledge",
    "knowledge-catalog",
    "mcp",
    "mcp-server",
    "audit",
    "sqlite",
    "fts5",
    "repository-management",
    "mcp-tool-shop"
  ]
}
